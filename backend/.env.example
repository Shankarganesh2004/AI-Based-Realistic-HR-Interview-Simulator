# ── Environment ──────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=ai_interview_platform

# JWT
JWT_SECRET_KEY=change-me-to-a-long-random-secret-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email (Gmail SMTP – enable "App Passwords")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# Gemini LLM (multi-key fallback)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_FALLBACK_API_KEYS=second-key,third-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=

# OpenRouter API (fallback when all Gemini keys exhausted)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-nano-30b-a3b:free,stepfun/step-3.5-flash:free

# Frontend URL (for CORS + email links)
FRONTEND_URL=http://localhost:5173

# Redis (optional)
REDIS_URL=redis://localhost:6379

# LiveKit Cloud (real-time video monitoring dashboard)
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
